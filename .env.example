# Copy to .env and fill in. Never commit the real .env.

# LLM (Google Gemini) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# x402 wallet (testnet only)
AGENT_PRIVATE_KEY=0x...
AGENT_WALLET_ADDRESS=0x...

# Network
NETWORK=eip155:84532
FACILITATOR_URL=https://facilitator.cdp.coinbase.com

# Set false to use real on-chain x402 payments (requires a funded testnet wallet).
# Leave true to simulate payments locally for the demo.
MOCK_PAYMENTS=true

# Budget caps (testnet USDC)
DAILY_CAP_USDC=1.00
PER_QUERY_CAP_USDC=0.05

# Servers
AGENT_PORT=8000
DATA_SERVER_PORT=8001
DATA_SERVER_BASE_URL=http://localhost:8001
DATA_SERVER_PAY_TO=0x000000000000000000000000000000000000dEaD

# Database
DB_PATH=nexuspay.db
